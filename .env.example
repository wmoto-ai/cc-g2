# Groq STT — API key for the Hub (server-side only, not exposed to the browser)
# Copy to .env.local and set your key.
GROQ_API_KEY=

# STT options (VITE_ vars are passed to the browser bundle by Vite)
VITE_GROQ_MODEL=whisper-large-v3-turbo
VITE_STT_ENABLED=true
VITE_STT_FORCE_ERROR=false

# Optional: Claude Code StatusLine hook integration
# Default is auto: if ~/.claude/settings.json has statusLine.command, cc-g2 wraps it automatically.
# Set to 0 to disable, or 1 to force-enable.
# CC_G2_ENABLE_STATUSLINE=0

# Notification Hub URL
# 通常は設定不要（ページのホスト名から自動解決される）
# 明示的に指定する場合のみ設定:
# VITE_HUB_URL=http://127.0.0.1:8787

# Hub auth token
# 通常は cc-g2 が自動生成して Vite dev server に注入するため設定不要
# 手動起動時のみ必要なら設定:
# VITE_HUB_TOKEN=replace-me

# Voice entry (G2 voice -> cc-g2 session launcher)
# Enabled by default. Set to 0 to disable.
# CC_G2_VOICE_ENTRY_ENABLED=0
# CC_G2_REPO_ROOTS=$HOME/Repos
# CC_G2_REPO_SCAN_DEPTH=3
